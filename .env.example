DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_application_id_here
DISCORD_GUILD_ID=your_guild_id_here

# IDs Discord (snowflakes) des utilisateurs autorisés à utiliser /session start|stop, séparés par des virgules
ALLOWED_USER_IDS=123456789012345678,987654321098765432

# DB_HOST: "mysql" en Docker, "127.0.0.1" en local
DB_HOST=mysql
DB_USER=root
DB_PASSWORD=example
DB_NAME=revealscope
